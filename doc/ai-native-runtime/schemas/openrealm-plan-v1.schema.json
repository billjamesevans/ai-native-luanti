{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/billjamesevans/ai-native-luanti/doc/ai-native-runtime/schemas/openrealm-plan-v1.schema.json",
  "title": "OpenRealm Plan v1",
  "description": "Public-safe data contract for Nova-created OpenRealm plans. Nova may propose this data; Luanti mutates only after validation, preview, approval, queued execution, audit, and rollback metadata.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "product",
    "assistant",
    "plan_id",
    "plan_kind",
    "title",
    "source_prompt",
    "created_at",
    "mod_name",
    "summary",
    "tags",
    "safety_budget",
    "nodes",
    "craft_items",
    "tools",
    "recipes",
    "ores",
    "structures",
    "world_recipe",
    "approval_steps",
    "ai_disclosure",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "const": "openrealm.plan.v1"
    },
    "product": {
      "const": "OpenRealm"
    },
    "assistant": {
      "const": "Nova"
    },
    "plan_id": {
      "type": "string",
      "pattern": "^orplan_[a-f0-9]{12}$"
    },
    "plan_kind": {
      "enum": [
        "structure",
        "ore_mod",
        "biome_recipe",
        "world_recipe"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "source_prompt": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "mod_name": {
      "$ref": "#/$defs/mod_name"
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "tags": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/identifier"
      },
      "maxItems": 32
    },
    "safety_budget": {
      "$ref": "#/$defs/safety_budget"
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node_def"
      }
    },
    "craft_items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/craft_item_def"
      }
    },
    "tools": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/tool_def"
      }
    },
    "recipes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/recipe"
      }
    },
    "ores": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ore_def"
      }
    },
    "structures": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/structure"
      }
    },
    "world_recipe": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/json_value"
      }
    },
    "approval_steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 200
      }
    },
    "ai_disclosure": {
      "$ref": "#/$defs/ai_disclosure"
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]{0,62}$"
    },
    "mod_name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]{1,62}$"
    },
    "node_name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]{1,62}:[a-z][a-z0-9_]{0,62}$"
    },
    "json_value": {
      "type": [
        "string",
        "number",
        "integer",
        "boolean",
        "object",
        "array",
        "null"
      ]
    },
    "groups": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0,
        "maximum": 10
      }
    },
    "safety_budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_node_definitions",
        "max_craft_items",
        "max_tools",
        "max_recipes",
        "max_ores",
        "max_structures",
        "max_structure_nodes",
        "requires_preview",
        "requires_approval",
        "rollback_required",
        "ai_direct_world_mutation_allowed"
      ],
      "properties": {
        "max_node_definitions": {
          "type": "integer",
          "minimum": 0,
          "maximum": 256
        },
        "max_craft_items": {
          "type": "integer",
          "minimum": 0,
          "maximum": 256
        },
        "max_tools": {
          "type": "integer",
          "minimum": 0,
          "maximum": 128
        },
        "max_recipes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 512
        },
        "max_ores": {
          "type": "integer",
          "minimum": 0,
          "maximum": 128
        },
        "max_structures": {
          "type": "integer",
          "minimum": 0,
          "maximum": 64
        },
        "max_structure_nodes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "requires_preview": {
          "const": true
        },
        "requires_approval": {
          "const": true
        },
        "rollback_required": {
          "const": true
        },
        "ai_direct_world_mutation_allowed": {
          "const": false
        }
      }
    },
    "node_def": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "description",
        "texture_hint",
        "groups",
        "light_source",
        "drawtype",
        "paramtype",
        "walkable"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/identifier"
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "texture_hint": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "groups": {
          "$ref": "#/$defs/groups"
        },
        "light_source": {
          "type": "integer",
          "minimum": 0,
          "maximum": 14
        },
        "drawtype": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "paramtype": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 64
        },
        "walkable": {
          "type": "boolean"
        }
      }
    },
    "craft_item_def": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "description",
        "inventory_image_hint"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/identifier"
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "inventory_image_hint": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        }
      }
    },
    "tool_def": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "description",
        "inventory_image_hint",
        "damage_groups",
        "full_punch_interval"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/identifier"
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "inventory_image_hint": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "damage_groups": {
          "$ref": "#/$defs/groups"
        },
        "full_punch_interval": {
          "type": "number",
          "minimum": 0.1,
          "maximum": 10
        }
      }
    },
    "recipe": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "output",
        "recipe"
      ],
      "properties": {
        "output": {
          "$ref": "#/$defs/node_name"
        },
        "recipe": {
          "type": "array",
          "minItems": 1,
          "maxItems": 9,
          "items": {
            "type": "array",
            "minItems": 1,
            "maxItems": 9,
            "items": {
              "type": "string",
              "maxLength": 128
            }
          }
        }
      }
    },
    "ore_def": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ore",
        "wherein",
        "clust_scarcity",
        "clust_num_ores",
        "clust_size",
        "y_min",
        "y_max"
      ],
      "properties": {
        "ore": {
          "$ref": "#/$defs/node_name"
        },
        "wherein": {
          "$ref": "#/$defs/node_name"
        },
        "clust_scarcity": {
          "type": "integer",
          "minimum": 1
        },
        "clust_num_ores": {
          "type": "integer",
          "minimum": 1
        },
        "clust_size": {
          "type": "integer",
          "minimum": 1
        },
        "y_min": {
          "type": "integer",
          "minimum": -31000,
          "maximum": 31000
        },
        "y_max": {
          "type": "integer",
          "minimum": -31000,
          "maximum": 31000
        }
      }
    },
    "structure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "description",
        "placements",
        "max_radius"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/identifier"
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        },
        "placements": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/placement"
          }
        },
        "max_radius": {
          "type": "integer",
          "minimum": 1,
          "maximum": 256
        }
      }
    },
    "placement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "x",
        "y",
        "z",
        "node"
      ],
      "properties": {
        "x": {
          "type": "integer"
        },
        "y": {
          "type": "integer"
        },
        "z": {
          "type": "integer"
        },
        "node": {
          "$ref": "#/$defs/node_name"
        }
      }
    },
    "ai_disclosure": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "ai_assisted",
        "human_approval_required",
        "direct_world_mutation_by_ai",
        "generated_code_is_template_based"
      ],
      "properties": {
        "ai_assisted": {
          "const": true
        },
        "assistant_name": {
          "const": "Nova"
        },
        "human_approval_required": {
          "const": true
        },
        "direct_world_mutation_by_ai": {
          "const": false
        },
        "generated_code_is_template_based": {
          "const": true
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/json_value"
      },
      "required": [
        "generator",
        "generator_version",
        "source"
      ],
      "properties": {
        "generator": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "generator_version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 40
        },
        "source": {
          "enum": [
            "prompt",
            "import",
            "template",
            "operator"
          ]
        }
      }
    }
  }
}
