{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/billjamesevans/ai-native-luanti/doc/ai-native-runtime/schemas/compatibility-apply-request.schema.json",
  "title": "AI-Native Luanti Compatibility Apply Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_version",
    "mode",
    "report_id",
    "report_version",
    "source_reference",
    "approved_actions",
    "target_world",
    "operator",
    "agent_id",
    "budget",
    "rollback_policy"
  ],
  "properties": {
    "request_version": {
      "type": "integer",
      "minimum": 1
    },
    "mode": {
      "enum": [
        "apply_plan",
        "apply"
      ]
    },
    "report_id": {
      "type": "string",
      "minLength": 1
    },
    "report_version": {
      "type": "integer",
      "minimum": 1
    },
    "source_reference": {
      "$ref": "#/$defs/source_reference"
    },
    "approved_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/approved_action"
      }
    },
    "target_world": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "world_id",
        "staging"
      ],
      "properties": {
        "world_id": {
          "type": "string",
          "minLength": 1
        },
        "staging": {
          "type": "boolean"
        }
      }
    },
    "operator": {
      "type": "string",
      "minLength": 1
    },
    "agent_id": {
      "type": "string",
      "minLength": 1
    },
    "budget": {
      "$ref": "#/$defs/apply_budget"
    },
    "rollback_policy": {
      "$ref": "#/$defs/rollback_policy"
    }
  },
  "$defs": {
    "source_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reference_type",
        "redacted_id",
        "inventory_hash"
      ],
      "properties": {
        "reference_type": {
          "enum": [
            "external_path",
            "content_address",
            "mounted_fixture"
          ]
        },
        "redacted_id": {
          "type": "string",
          "minLength": 1
        },
        "inventory_hash": {
          "$ref": "#/$defs/sha256_hash"
        }
      }
    },
    "approved_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_index",
        "action",
        "status"
      ],
      "properties": {
        "action_index": {
          "type": "integer",
          "minimum": 0
        },
        "action": {
          "enum": [
            "copy_asset_reference",
            "map_texture",
            "map_sound",
            "register_node_alias",
            "register_entity_stub",
            "import_structure",
            "skip_feature"
          ]
        },
        "status": {
          "enum": [
            "supported",
            "partial",
            "skipped"
          ]
        }
      }
    },
    "apply_budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_media_files",
        "max_entity_definitions",
        "max_node_writes_total",
        "max_node_writes_per_step",
        "max_manual_review_items",
        "max_wall_time_ms"
      ],
      "properties": {
        "max_media_files": {
          "type": "integer",
          "minimum": 0
        },
        "max_entity_definitions": {
          "type": "integer",
          "minimum": 0
        },
        "max_node_writes_total": {
          "type": "integer",
          "minimum": 0
        },
        "max_node_writes_per_step": {
          "type": "integer",
          "minimum": 0
        },
        "max_manual_review_items": {
          "type": "integer",
          "minimum": 0
        },
        "max_wall_time_ms": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "rollback_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy",
        "metadata_required"
      ],
      "properties": {
        "policy": {
          "enum": [
            "snapshot",
            "manifest_only",
            "no_world_mutation"
          ]
        },
        "metadata_required": {
          "const": true
        }
      }
    },
    "sha256_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
